# ============================================
# Goldgem ERP — Cloud Deployment (Vercel + Neon)
# ============================================
# Get your Neon database URL from: https://console.neon.tech
# Replace the values below with your actual Neon credentials

# Pooler URL (used by app at runtime — connects via PgBouncer)
DATABASE_URL="postgresql://neondb_owner:npg_xxxxxxxxxxxxxxxxxxxx@ep-cool-name-12345678.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct URL (used by Prisma Migrate — connects directly)
DIRECT_URL="postgresql://neondb_owner:npg_xxxxxxxxxxxxxxxxxxxx@ep-cool-name-12345678.us-east-2.aws.neon.tech/neondb?sslmode=require"
