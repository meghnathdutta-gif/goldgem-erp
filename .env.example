# ============================================
# GoldGem ERP - Environment Variables
# ============================================
# Copy this file as .env and fill in your values
#
# For LOCAL development (SQLite):
#   DATABASE_URL="file:./dev.db"
#
# For PRODUCTION (Neon PostgreSQL):
#   DATABASE_URL="postgresql://username:password@ep-xxx-xx-xxxxxx.region.aws.neon.tech/goldgem?sslmode=require"
#
# Get your Neon DATABASE_URL from:
#   https://console.neon.tech → Your Project → Dashboard → Connection string
# ============================================

DATABASE_URL="file:./dev.db"
