# ============================================
# GoldGem ERP - Environment Variables
# ============================================
# Copy this file as .env and fill in your values
#
# For LOCAL development (SQLite):
#   1. Copy prisma/schema.sqlite.prisma over prisma/schema.prisma
#   2. Set DATABASE_URL="file:./dev.db"
#   3. Run: npx prisma db push
#
# For PRODUCTION (Vercel + Neon PostgreSQL):
#   1. Keep prisma/schema.prisma as-is (PostgreSQL)
#   2. Set DATABASE_URL and DIRECT_URL from Neon console
#   3. Run: npx prisma db push
#
# Get your Neon DATABASE_URL from:
#   https://console.neon.tech → Your Project → Dashboard → Connection string
# ============================================

# Production (Neon PostgreSQL) - USED BY VERCEL
DATABASE_URL="postgresql://username:password@ep-xxx-xx-xxxxxx.region.aws.neon.tech/goldgem?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-xxx-xx-xxxxxx.region.aws.neon.tech/goldgem?sslmode=require"

# Local development (SQLite) - Uncomment below and switch schema
# DATABASE_URL="file:./dev.db"
