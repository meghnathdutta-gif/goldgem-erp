generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("staff")
  avatar    String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salesOrders     SalesOrder[]
  posTransactions PosTransaction[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products Product[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  sku            String   @unique
  barcode        String?
  description    String?
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  price          Float
  costPrice      Float
  unit           String   @default("piece")
  minStockLevel  Int      @default(10)
  imageUrl       String?
  isActive       Boolean  @default(true)
  isManufactured Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  inventoryItems     InventoryItem[]
  bomComponents      BomComponent[]  @relation("ProductBom")
  bomAssemblies      BomComponent[]  @relation("ProductAssembly")
  workOrderProducts  WorkOrderProduct[]
  orderItems         SalesOrderItem[]
  posItems           PosTransactionItem[]
  ecommerceItems     EcommerceOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  shipmentItems      ShipmentItem[]
  demandForecasts    DemandForecast[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  phone     String?
  manager   String?
  capacity  Int      @default(1000)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
}

model InventoryItem {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  quantity     Int       @default(0)
  reservedQty  Int       @default(0)
  reorderPoint Int       @default(20)
  reorderQty   Int       @default(100)
  batchNumber  String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  movements InventoryMovement[]
}

model InventoryMovement {
  id              String         @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  type            String
  quantity        Int
  reference       String?
  notes           String?
  performedBy     String?
  createdAt       DateTime       @default(now())
}

model Supplier {
  id           String  @id @default(cuid())
  name         String
  code         String  @unique
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?
  gstNumber    String?
  rating       Float   @default(3.0)
  leadTimeDays Int     @default(7)
  paymentTerms String?
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  status       String   @default("draft")
  orderDate    DateTime @default(now())
  expectedDate DateTime?
  totalAmount  Float    @default(0)
  taxAmount    Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items     PurchaseOrderItem[]
  shipments Shipment[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  receivedQty     Int           @default(0)
}

model Shipment {
  id             String        @id @default(cuid())
  shipmentNumber String        @unique
  purchaseOrderId String?
  purchaseOrder  PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  status         String        @default("pending")
  carrier        String?
  trackingNumber String?
  shippingDate   DateTime?
  deliveryDate   DateTime?
  origin         String?
  destination    String?
  cost           Float         @default(0)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items ShipmentItem[]
}

model ShipmentItem {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
}

model BomComponent {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation("ProductBom", fields: [productId], references: [id])
  componentId String
  component   Product @relation("ProductAssembly", fields: [componentId], references: [id])
  quantity    Float   @default(1)
  notes       String?
}

model WorkOrder {
  id           String   @id @default(cuid())
  woNumber     String   @unique
  status       String   @default("planned")
  priority     String   @default("medium")
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  products WorkOrderProduct[]
}

model WorkOrderProduct {
  id           String     @id @default(cuid())
  workOrderId  String
  workOrder    WorkOrder  @relation(fields: [workOrderId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  targetQty    Int
  completedQty Int        @default(0)
  wastageQty   Int        @default(0)
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  gstNumber String?
  type      String   @default("retail")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salesOrders     SalesOrder[]
  ecommerceOrders EcommerceOrder[]
}

model SalesOrder {
  id           String   @id @default(cuid())
  soNumber     String   @unique
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  status       String   @default("draft")
  orderDate    DateTime @default(now())
  deliveryDate DateTime?
  totalAmount  Float    @default(0)
  taxAmount    Float    @default(0)
  discount     Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items SalesOrderItem[]
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Float
  totalPrice   Float
}

model PosTransaction {
  id                String   @id @default(cuid())
  transactionNumber String   @unique
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
  customerName      String?
  subtotal          Float
  taxAmount         Float    @default(0)
  discount          Float    @default(0)
  totalAmount       Float
  paymentMethod     String   @default("cash")
  status            String   @default("completed")
  createdAt         DateTime @default(now())
  items PosTransactionItem[]
}

model PosTransactionItem {
  id               String         @id @default(cuid())
  posTransactionId String
  posTransaction   PosTransaction @relation(fields: [posTransactionId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  productName      String
  quantity         Int
  unitPrice        Float
  totalPrice       Float
}

model EcommerceOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  status          String   @default("pending")
  orderDate       DateTime @default(now())
  shippingAddress String?
  billingAddress  String?
  totalAmount     Float    @default(0)
  taxAmount       Float    @default(0)
  shippingCost    Float    @default(0)
  paymentMethod   String   @default("online")
  paymentStatus   String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items EcommerceOrderItem[]
}

model EcommerceOrderItem {
  id               String         @id @default(cuid())
  ecommerceOrderId String
  ecommerceOrder   EcommerceOrder @relation(fields: [ecommerceOrderId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  productName      String
  quantity         Int
  unitPrice        Float
  totalPrice       Float
}

model DemandForecast {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  period          String
  predictedDemand Int
  confidence      Float    @default(0.0)
  model           String   @default("prophet")
  createdAt       DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  user      String?
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
