// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("staff") // admin, manager, staff, cashier
  avatar    String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrders      SalesOrder[]
  posTransactions  PosTransaction[]
}

// ============================================
// PRODUCT & CATEGORY
// ============================================
model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  barcode       String?
  description   String?
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String
  price         Float
  costPrice     Float
  unit          String   @default("piece") // piece, kg, liter, meter
  minStockLevel Int      @default(10)
  imageUrl      String?
  isActive      Boolean  @default(true)
  isManufactured Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryItems     InventoryItem[]
  bomComponents      BomComponent[]     @relation("ProductBom")
  bomAssemblies      BomComponent[]     @relation("ProductAssembly")
  workOrderProducts  WorkOrderProduct[]
  orderItems         SalesOrderItem[]
  posItems           PosTransactionItem[]
  ecommerceItems     EcommerceOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  shipmentItems      ShipmentItem[]
  demandForecasts    DemandForecast[]
}

// ============================================
// INVENTORY & WAREHOUSE
// ============================================
model Warehouse {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  city        String?
  phone       String?
  manager     String?
  capacity    Int      @default(1000)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
}

model InventoryItem {
  id          String    @id @default(cuid())
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String
  quantity    Int       @default(0)
  reservedQty Int       @default(0)
  reorderPoint Int      @default(20)
  reorderQty  Int       @default(100)
  batchNumber String?
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  movements InventoryMovement[]
}

model InventoryMovement {
  id            String         @id @default(cuid())
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  warehouseId   String
  type          String         // in, out, transfer, adjustment, return
  quantity      Int
  reference     String?        // PO number, SO number, etc.
  notes         String?
  performedBy   String?
  createdAt     DateTime       @default(now())
}

// ============================================
// SUPPLIER & PURCHASE ORDER (Supply Chain)
// ============================================
model Supplier {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  gstNumber   String?
  rating      Float    @default(3.0)
  leadTimeDays Int     @default(7)
  paymentTerms String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNumber      String   @unique
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  supplierId    String
  status        String   @default("draft") // draft, sent, confirmed, partial, received, cancelled
  orderDate     DateTime @default(now())
  expectedDate  DateTime?
  totalAmount   Float    @default(0)
  taxAmount     Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items        PurchaseOrderItem[]
  shipments    Shipment[]
}

model PurchaseOrderItem {
  id              String       @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  product         Product      @relation(fields: [productId], references: [id])
  productId       String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  receivedQty     Int          @default(0)
}

// ============================================
// SHIPMENT (Supply Chain Logistics)
// ============================================
model Shipment {
  id              String       @id @default(cuid())
  shipmentNumber  String       @unique
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?
  status          String       @default("pending") // pending, shipped, in_transit, delivered, cancelled
  carrier         String?
  trackingNumber  String?
  shippingDate    DateTime?
  deliveryDate    DateTime?
  origin          String?
  destination     String?
  cost            Float        @default(0)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items ShipmentItem[]
}

model ShipmentItem {
  id          String    @id @default(cuid())
  shipment    Shipment  @relation(fields: [shipmentId], references: [id])
  shipmentId  String
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  quantity    Int
}

// ============================================
// MANUFACTURING (BOM & Work Orders)
// ============================================
model BomComponent {
  id             String  @id @default(cuid())
  product        Product @relation("ProductBom", fields: [productId], references: [id])
  productId      String
  component      Product @relation("ProductAssembly", fields: [componentId], references: [id])
  componentId    String
  quantity       Float   @default(1)
  notes          String?
}

model WorkOrder {
  id            String   @id @default(cuid())
  woNumber      String   @unique
  status        String   @default("planned") // planned, in_progress, completed, cancelled
  priority      String   @default("medium") // low, medium, high, urgent
  plannedStart  DateTime?
  plannedEnd    DateTime?
  actualStart   DateTime?
  actualEnd     DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products WorkOrderProduct[]
}

model WorkOrderProduct {
  id           String     @id @default(cuid())
  workOrder    WorkOrder  @relation(fields: [workOrderId], references: [id])
  workOrderId  String
  product      Product    @relation(fields: [productId], references: [id])
  productId    String
  targetQty    Int
  completedQty Int        @default(0)
  wastageQty   Int        @default(0)
}

// ============================================
// SALES ORDER
// ============================================
model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  gstNumber   String?
  type        String   @default("retail") // retail, wholesale, online
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesOrders     SalesOrder[]
  ecommerceOrders EcommerceOrder[]
}

model SalesOrder {
  id            String   @id @default(cuid())
  soNumber      String   @unique
  customer      Customer @relation(fields: [customerId], references: [id])
  customerId    String
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  status        String   @default("draft") // draft, confirmed, processing, shipped, delivered, cancelled
  orderDate     DateTime @default(now())
  deliveryDate  DateTime?
  totalAmount   Float    @default(0)
  taxAmount     Float    @default(0)
  discount      Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items SalesOrderItem[]
}

model SalesOrderItem {
  id            String     @id @default(cuid())
  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  salesOrderId  String
  product       Product    @relation(fields: [productId], references: [id])
  productId     String
  quantity      Int
  unitPrice     Float
  totalPrice    Float
}

// ============================================
// POS (Point of Sale)
// ============================================
model PosTransaction {
  id            String   @id @default(cuid())
  transactionNumber String @unique
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  customerName  String?
  subtotal      Float
  taxAmount     Float    @default(0)
  discount      Float    @default(0)
  totalAmount   Float
  paymentMethod String   @default("cash") // cash, card, upi, mixed
  status        String   @default("completed") // completed, refunded, cancelled
  createdAt     DateTime @default(now())

  items PosTransactionItem[]
}

model PosTransactionItem {
  id              String           @id @default(cuid())
  posTransaction  PosTransaction   @relation(fields: [posTransactionId], references: [id])
  posTransactionId String
  product         Product          @relation(fields: [productId], references: [id])
  productId       String
  productName     String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
}

// ============================================
// E-COMMERCE
// ============================================
model EcommerceOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  customer      Customer @relation(fields: [customerId], references: [id])
  customerId    String
  status        String   @default("pending") // pending, confirmed, processing, shipped, delivered, cancelled
  orderDate     DateTime @default(now())
  shippingAddress String?
  billingAddress  String?
  totalAmount   Float    @default(0)
  taxAmount     Float    @default(0)
  shippingCost  Float    @default(0)
  paymentMethod String   @default("online")
  paymentStatus String   @default("pending") // pending, paid, refunded
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items EcommerceOrderItem[]
}

model EcommerceOrderItem {
  id              String          @id @default(cuid())
  ecommerceOrder  EcommerceOrder  @relation(fields: [ecommerceOrderId], references: [id])
  ecommerceOrderId String
  product         Product         @relation(fields: [productId], references: [id])
  productId       String
  productName     String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
}

// ============================================
// AI/ML DEMAND FORECAST
// ============================================
model DemandForecast {
  id          String   @id @default(cuid())
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  period      String   // "2026-01", "2026-W03", etc.
  predictedDemand Int
  confidence  Float    @default(0.0)
  model       String   @default("prophet") // prophet, arima, lstm
  createdAt   DateTime @default(now())
}

// ============================================
// AUDIT LOG
// ============================================
model AuditLog {
  id        String   @id @default(cuid())
  user      String?
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
